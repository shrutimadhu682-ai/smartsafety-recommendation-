# ZENSAFE Environment Variables
# Copy this file to .env and fill in values

# Server
PORT=3000
NODE_ENV=development

# Database
# Leave blank to use default ./data/zensafe.db
DB_PATH=

# Security
# In production: set to your deployment domain
ALLOWED_ORIGIN=

# Optional: session secret (for future auth)
SESSION_SECRET=zensafe_change_this_in_production
